# Copyright 2023 Intrinsic Innovation LLC

# A single source of truth for recording data categories, event source matchers,
# and what constitutes a "lightweight" event source across the stack.
#
# Proto definition (RecordingDataCategories): intrinsic/logging/proto/recording_data_categories.proto
#
# Note: Some files might still need some changes propagated.
categories: {
  category_id: "text_logs"
  display_name: "Text logs"
  description: "Includes all text logs (including ones from user installed assets)."
  event_sources: [
    "/text-log-out",
    "/asset-text-log-out"
  ]
  is_lightweight: true
}
categories: {
  category_id: "flowstate_data"
  display_name: "Flowstate data"
  description: "Includes Flowstate data, such as Flowstate events."
  event_sources: [
    "/flowstate_events"
  ]
  is_lightweight: true
}
categories: {
  category_id: "scene_data"
  display_name: "Scene data"
  description: "Includes scene data, such as TFs, world geometries, and markers."
  event_sources: [
    "/assets/.*/markers",
    "/tf",
    "/tf_associations",
    "trace_cube_.*"
  ]
  is_lightweight: false
}
categories: {
  category_id: "robot_data"
  display_name: "Robot data"
  description: "Includes robot-related data, such as robot status and motion planning information."
  event_sources: [
    "motion_planner_service.PlanTrajectory.debug_data",
    "/icon/.*/robot_status"
  ]
  is_lightweight: false
}
categories: {
  category_id: "perception_data"
  display_name: "Perception data"
  description: "Includes perception data, such as camera images and pose estimations."
  event_sources: [
    "perception.*"
  ]
  is_lightweight: false
}
categories: {
  category_id: "debug_data"
  display_name: "Debug data"
  description: "Includes debug data, such as system metrics and the executive state."
  event_sources: [
    "executive.*",
    "/system/metrics",
    "error_report"
  ]
  is_lightweight: false
}
categories: {
  category_id: "skill_data"
  display_name: "Skill data"
  description: "Includes skill data, such as skill inputs and execution results."
  event_sources: [
    "skills..*"
  ]
  is_lightweight: false
}
