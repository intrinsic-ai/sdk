########
# CUDA #
########

bazel_dep(name = "rules_cuda", version = "0.2.5")
archive_override(
    module_name = "rules_cuda",
    integrity = "sha256-9+5i1Idf9suS1PLA5EJzsFX4lT3yMn9oeFd+y8b+vUY=",
    strip_prefix = "rules_cuda-1bc391d927066ff35291186aa7a51d37f92f44f3",
    url = "https://github.com/bazel-contrib/rules_cuda/archive/1bc391d927066ff35291186aa7a51d37f92f44f3.zip",
)

cuda = use_extension("@rules_cuda//cuda:extensions.bzl", "toolchain")

# cccl, cudart, nvcc are mandatory and needed for basic cuda support.
cuda.component(
    name = "cuda_cccl",
    component_name = "cccl",
    strip_prefix = "cuda_cccl-linux-x86_64-12.3.101-archive",
    urls = ["https://developer.download.nvidia.com/compute/cuda/redist/cuda_cccl/linux-x86_64/cuda_cccl-linux-x86_64-12.3.101-archive.tar.xz"],
)
cuda.component(
    name = "cuda_cudart",
    component_name = "cudart",
    strip_prefix = "cuda_cudart-linux-x86_64-12.3.101-archive",
    urls = ["https://developer.download.nvidia.com/compute/cuda/redist/cuda_cudart/linux-x86_64/cuda_cudart-linux-x86_64-12.3.101-archive.tar.xz"],
)
cuda.component(
    name = "cuda_nvcc",
    component_name = "nvcc",
    strip_prefix = "cuda_nvcc-linux-x86_64-12.3.107-archive",
    urls = ["https://developer.download.nvidia.com/compute/cuda/redist/cuda_nvcc/linux-x86_64/cuda_nvcc-linux-x86_64-12.3.107-archive.tar.xz"],
)

# curand is needed for compiling cuda with clang
cuda.component(
    name = "cuda_curand",
    component_name = "curand",
    strip_prefix = "libcurand-linux-x86_64-10.3.4.107-archive",
    urls = ["https://developer.download.nvidia.com/compute/cuda/redist/libcurand/linux-x86_64/libcurand-linux-x86_64-10.3.4.107-archive.tar.xz"],
)
cuda.toolkit(
    name = "cuda",
    components_mapping = {
        "cccl": "@cuda_cccl",
        "cudart": "@cuda_cudart",
        "curand": "@cuda_curand",
        "nvcc": "@cuda_nvcc",
    },
    version = "12.3.2",
)
use_repo(
    cuda,
    "cuda",
    "cuda_cccl",
    "cuda_cudart",
    "cuda_curand",
    "cuda_nvcc",
)

