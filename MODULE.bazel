# https://github.com/google/copybara?tab=readme-ov-file#using-pre-built-copybara-in-bazel
http_jar(
    name = "com_github_google_copybara",
    sha256 = "511989edb17239cbccefb758d8bfcdec89b4294f11e5c70df694ad89698f2ab3",
    urls = ["https://github.com/google/copybara/releases/download/v20251215/copybara_deploy.jar"],
)

